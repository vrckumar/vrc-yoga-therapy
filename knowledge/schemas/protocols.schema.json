{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "protocols.schema.json",
  "title": "protocols",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocol_id": {
      "type": "string",
      "pattern": "^PR\\d{3,}$"
    },
    "protocol_name": {
      "type": "string"
    },
    "section_id": {
      "type": "string"
    },
    "primary_ailment_id": {
      "type": "string"
    },
    "primary_condition_id": {
      "type": "string"
    },
    "meaning_function": {
      "type": "string"
    },
    "source_doc": {
      "type": "string"
    },
    "active_flag": {
      "type": "boolean"
    }
  },
  "required": [
    "protocol_id",
    "protocol_name",
    "section_id",
    "primary_ailment_id",
    "primary_condition_id",
    "meaning_function",
    "source_doc",
    "active_flag"
  ]
}
